# =============================================================================
# PSI Finance — Polygon mainnet deployment env
# =============================================================================
# Copy this file to .env and fill in the secret values. Never commit .env.
# All "0x..." values below are the addresses Robin Markets used in their
# audited mainnet deployment — see docs/POLYGON_DEPS.md for provenance.
# =============================================================================

# --- RPC + verification ------------------------------------------------------
POLYGON_RPC_URL=
POLYGONSCAN_API_KEY=

# --- Deployer key (testnet/local only — use a hardware wallet for mainnet) ---
DEPLOYER_PRIVATE_KEY=

# --- PSI protocol config -----------------------------------------------------
# Owner gets DEFAULT_ADMIN, DEFAULT_MANAGER, FEE_HARVESTER, PAUSER, and
# EXTERNAL_VAULT_MANAGER roles. Should be a multisig for mainnet.
PSI_OWNER=

# TimelockController minimum delay in seconds. Robin used 86400 (24h).
PSI_TIMELOCK_MIN_DELAY=86400

# Protocol fee in basis points (10000 = 100%). Robin deployed mainnet with 0.
# Doc default suggested 100 (1%). Pick deliberately.
PSI_PROTOCOL_FEE_BPS=0

# EIP-712 signer for TWAP submissions. Should be isolated from web servers
# (HSM, KMS, or dedicated signer service).
PSI_TWAP_SIGNER=

# ERC-1155 metadata URI template. Production host once API is live.
PSI_METADATA_URI=https://api.psi.finance/v1/shares/{id}

# --- Polymarket Polygon dependencies -----------------------------------------
# Sourced from Robin's actual mainnet deployment broadcast at
# broadcast/DeployRobinStakingVault.s.sol/137/run-1776211857782.json.
# See docs/POLYGON_DEPS.md for the rationale on V1 vs V2 / USDC.e vs pUSD.

# Conditional Tokens Framework (CTF) — same in V1 and V2
POLYMARKET_CTF=0x4d97dcd97ec945f40cf65f87097ace5ea0476045

# Neg Risk Adapter — same in V1 and V2
POLYMARKET_NEG_RISK_ADAPTER=0xd91e80cf2e7be2e162c6513ced06f1dd0da35296

# CTF Exchange (V1) — what Robin's audited code targets.
# V2 alternative per official docs: 0xe111180000d2663c0091e4f400237545b87b996b
POLYMARKET_CTF_EXCHANGE=0x4bfb41d5b3570defd03c39a9a4d8de6bd8b8982e

# Neg Risk CTF Exchange (V1) — what Robin's audited code targets.
# V2 alternative per official docs: 0xe2222d279d744050d28e00520010520000310f59
POLYMARKET_NEG_RISK_CTF_EXCHANGE=0xc5d563a36ae78145c45a50134d48a1215220f80a

# Collateral: USDC.e (bridged USDC) — what Robin's audited code targets.
# pUSD alternative per official docs: 0xc011a7e12a19f7b1f670d46f03b03f3342e82dfb
POLYMARKET_COLLATERAL=0x2791bca1f2de4661ed88a30c99a7a9449aa84174

# Wrapped collateral (polymarketWcol). Source: Robin's mainnet deploy.
POLYMARKET_WCOL=0x3a3bd7bb9528e159577f7c2e685cc81a765002e2
